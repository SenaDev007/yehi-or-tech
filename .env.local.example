# Base de données
DATABASE_URL="postgresql://user:password@localhost:5432/yehiortech"

# Auth (JWT manuel — pas NextAuth)
JWT_SECRET="[générer avec: openssl rand -base64 64]"
JWT_EXPIRES_IN="7d"

# Emails
RESEND_API_KEY="re_..."
FROM_EMAIL="contact@yehiortech.com"
ADMIN_EMAIL="contact@yehiortech.com"

# Anthropic (Elior IA)
ANTHROPIC_API_KEY="sk-ant-..."

# Meta (WhatsApp / Facebook webhooks)
META_VERIFY_TOKEN="[token aléatoire à définir]"
META_APP_SECRET="[depuis Meta Developers]"

# App
NEXT_PUBLIC_SITE_URL="https://yehiortech.com"
NEXT_PUBLIC_ADMIN_URL="https://admin.yehiortech.com"
# Lien vers la page devis (ex: /devis pour page intégrée, ou URL externe si sous-domaine dédié)
NEXT_PUBLIC_DEVIS_URL="/devis"

# Umami (analytics self-hosted)
NEXT_PUBLIC_UMAMI_ID="[ID depuis votre instance Umami]"
NEXT_PUBLIC_UMAMI_URL="https://analytics.yehiortech.com"
