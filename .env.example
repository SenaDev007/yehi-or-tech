# URLs publiques (exposées au client)
# SITE_URL : URL du site (sans slash final)
NEXT_PUBLIC_SITE_URL="https://yehiortech.com"
# DEVIS_URL : page devis. Même domaine = /devis (lien interne). Sous-domaine externe = URL complète.
# Tant que devis.yehiortech.com n'existe pas, laisser vide ou /devis pour utiliser la page intégrée.
NEXT_PUBLIC_DEVIS_URL="/devis"

