# Base de données (obligatoire)
# Sur Vercel : Vercel Postgres, Neon, Supabase ou autre PostgreSQL
# Si pooler (Neon/Supabase) : ajouter aussi DIRECT_URL pour les migrations
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Auth JWT (obligatoire en production)
