# ─────────────────────────────────────────────────────────────
# Variables d'environnement — YEHI OR Tech (Vercel / production)
# Copier vers .env.local en local, et les ajouter dans Vercel.
# ─────────────────────────────────────────────────────────────

# Base de données (obligatoire)
# Sur Vercel : Vercel Postgres, Neon, Supabase ou autre PostgreSQL
# Si pooler (Neon/Supabase) : ajouter aussi DIRECT_URL pour les migrations
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Auth JWT (obligatoire en production)
# Générer une valeur forte aléatoire (ex: openssl rand -base64 64)
JWT_SECRET="[VOTRE_JWT_SECRET_ICI]"
JWT_EXPIRES_IN="7d"

# Emails (Resend)
RESEND_API_KEY="re_..."
FROM_EMAIL="contact@yehiortech.com"
ADMIN_EMAIL="contact@yehiortech.com"

# Anthropic — Elior IA (chat)
# Ne JAMAIS mettre la vraie clé dans les fichiers commités.
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Meta — Webhooks WhatsApp / Facebook (optionnel)
META_VERIFY_TOKEN="[token aléatoire]"
META_APP_SECRET="[depuis Meta Developers]"

# URLs publiques (exposées au client)
# SITE_URL : URL du site (sans slash final)
NEXT_PUBLIC_SITE_URL="https://yehiortech.com"
# DEVIS_URL : page devis. Même domaine = /devis (lien interne). Sous-domaine externe = URL complète.
# Tant que devis.yehiortech.com n'existe pas, laisser vide ou /devis pour utiliser la page intégrée.
NEXT_PUBLIC_DEVIS_URL="/devis"

# Analytics Umami (optionnel)
# NEXT_PUBLIC_UMAMI_ID="..."
# NEXT_PUBLIC_UMAMI_URL="https://analytics.yehiortech.com"
